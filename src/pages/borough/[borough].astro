---
import Base from '../../layouts/Base.astro';
import ListingCard from '../../components/ListingCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import {
  restaurants,
  getRestaurantsByBorough,
  boroughMeta,
  neighbourhoodMeta,
  type Borough,
} from '../../data/restaurants';

export function getStaticPaths() {
  return Object.keys(boroughMeta).map((slug) => ({
    params: { borough: slug },
  }));
}

const { borough } = Astro.params as { borough: Borough };
const meta = boroughMeta[borough];
const listings = getRestaurantsByBorough(borough);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://kidfriendlylondon.co.uk' },
    { '@type': 'ListItem', position: 2, name: meta.name, item: `https://kidfriendlylondon.co.uk/${borough}` },
  ],
};
---

<Base
  title={`Kid-Friendly Restaurants in ${meta.name} | Kid Friendly London`}
  description={`The best family restaurants in ${meta.name}. ${meta.description} Browse ${listings.length}+ enriched listings with filters for kids menu, highchairs, outdoor space, buggy access and more.`}
  schema={breadcrumbSchema}
>
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span>{meta.name}</span>
      </nav>

      <p class="page-hero__tag">Family dining guide</p>
      <h1>Kid-Friendly Restaurants in {meta.name}</h1>
      <p style="color:var(--color-text-muted);max-width:65ch;margin-top:0.75rem;font-size:1.05rem">
        {meta.description}
      </p>

      <div class="page-hero__stats">
        <div class="stat">
          <span class="stat__value">{listings.length}</span>
          <span class="stat__label">restaurants reviewed</span>
        </div>
        <div class="stat">
          <span class="stat__value">{meta.neighbourhoods.length}</span>
          <span class="stat__label">neighbourhoods covered</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container" style="padding-top:2rem;padding-bottom:4rem">
    <!-- Neighbourhood sub-links -->
    {meta.neighbourhoods.length > 0 && (
      <div style="margin-bottom:2.5rem">
        <h2 style="margin-bottom:1rem">Browse by neighbourhood</h2>
        <div class="neighbourhood-grid">
          {meta.neighbourhoods.map((slug) => {
            const nm = neighbourhoodMeta[slug];
            const count = restaurants.filter((r) => r.neighbourhood === slug).length;
            return (
              <a href={`/${slug}`} class="neighbourhood-card">
                <div class="neighbourhood-card__name">{nm.name}</div>
                <div class="neighbourhood-card__count">{count} restaurants</div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <div class="ad-unit">Advertisement</div>

    <FilterBar />

    <div class="listings-grid" id="listings-grid">
      {listings.map((r) => <ListingCard restaurant={r} />)}
    </div>
    <div id="no-results" class="no-results" style="display:none">
      <p>No restaurants match your current filters.</p>
    </div>

    <div class="ad-unit" style="margin-top:2rem">Advertisement</div>
  </div>

  <section class="email-signup">
    <div class="container">
      <h2>Get our free guide: London's 20 best restaurants for under-5s</h2>
      <p>Monthly roundups and the best family dining across {meta.name} and all of London.</p>
      <form class="email-form" action="#" method="POST">
        <input type="email" name="EMAIL" placeholder="Your email address" required />
        <button type="submit">Get the free guide →</button>
      </form>
      <p class="email-signup__small">No spam. Unsubscribe any time.</p>
    </div>
  </section>
</Base>
