---
import Base from '../layouts/Base.astro';
import ListingCard from '../components/ListingCard.astro';
import { restaurants, getFeaturedRestaurants, neighbourhoodMeta } from '../data/restaurants';

const featured = getFeaturedRestaurants();
const totalListings = restaurants.length;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Kid Friendly London',
  url: 'https://kidfriendlylondon.co.uk',
  description:
    'The most comprehensive guide to kid-friendly and family restaurants in London. Filter by neighbourhood, features, price, and more.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://kidfriendlylondon.co.uk/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<Base
  title="Kid Friendly Restaurants London — Family Dining Guide | Kid Friendly London"
  description="The most comprehensive guide to kid-friendly restaurants in London. Filter by neighbourhood, highchairs, kids menu, outdoor space, buggy access and more. 50+ enriched listings across Clapham, Notting Hill, Islington, Richmond and Shoreditch."
  schema={schema}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero__eyebrow">London's most detailed family dining guide</p>
      <h1 class="hero__title">
        Kid-Friendly Restaurants<br />in London
      </h1>
      <p class="hero__subtitle">
        More than a list — every restaurant is enriched with the details that actually matter to parents: highchairs, buggy access, kids menus, outdoor space, noise level, and age suitability.
      </p>

      <div class="hero__search">
        <input
          type="search"
          id="hero-search"
          placeholder="Search by restaurant name or neighbourhood..."
          aria-label="Search restaurants"
        />
        <button type="button" id="hero-search-btn">Search</button>
      </div>

      <div class="hero__trust">
        <div class="trust-item"><span>✅</span> {totalListings}+ restaurants reviewed</div>
        <div class="trust-item"><span>📍</span> 5 London neighbourhoods</div>
        <div class="trust-item"><span>🔄</span> Updated weekly</div>
        <div class="trust-item"><span>👨‍👩‍👧</span> Built by parents, for parents</div>
      </div>
    </div>
  </section>

  <!-- Neighbourhood quick-links -->
  <section class="section section--soft">
    <div class="container">
      <h2 style="margin-bottom:1.5rem">Browse by neighbourhood</h2>
      <div class="neighbourhood-grid">
        {Object.entries(neighbourhoodMeta).map(([slug, meta]) => {
          const count = restaurants.filter((r) => r.neighbourhood === slug).length;
          return (
            <a href={`/${slug}`} class="neighbourhood-card">
              <div class="neighbourhood-card__emoji">
                {slug === 'clapham' ? '🌿' : slug === 'notting-hill' ? '🎡' : slug === 'islington' ? '🎭' : slug === 'richmond' ? '🦌' : '🎨'}
              </div>
              <div class="neighbourhood-card__name">{meta.name}</div>
              <div class="neighbourhood-card__count">{count} restaurants</div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Featured listings -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom:0.5rem">Featured restaurants</h2>
      <p class="text-muted" style="margin-bottom:1.5rem">Handpicked favourites — the best of the best for London families.</p>
      <div class="listings-grid">
        {featured.map((r) => <ListingCard restaurant={r} />)}
      </div>
    </div>
  </section>

  <!-- Borough links -->
  <section class="section section--soft">
    <div class="container">
      <h2 style="margin-bottom:1.5rem">Browse by borough</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem">
        {[
          { href: '/south-london', name: 'South London', emoji: '🌳', desc: 'Clapham, Richmond' },
          { href: '/north-london', name: 'North London', emoji: '🎭', desc: 'Islington, Highbury' },
          { href: '/west-london', name: 'West London', emoji: '🎡', desc: 'Notting Hill, Kensington' },
          { href: '/east-london', name: 'East London', emoji: '🎨', desc: 'Shoreditch, Spitalfields' },
        ].map((b) => (
          <a href={b.href} class="neighbourhood-card">
            <div class="neighbourhood-card__emoji">{b.emoji}</div>
            <div class="neighbourhood-card__name">{b.name}</div>
            <div class="neighbourhood-card__count">{b.desc}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AdSense unit (below fold) -->
  <div class="container">
    <div class="ad-unit">Advertisement — Google AdSense (insert ad code here)</div>
  </div>

  <!-- What makes us different -->
  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center">
        <div>
          <h2 style="margin-bottom:1rem">Why Kid Friendly London is different</h2>
          <p style="margin-bottom:1.5rem;color:var(--color-text-muted)">
            Every other list tells you a restaurant is "family-friendly." We tell you <em>why</em> — and exactly what to expect.
          </p>
          <ul style="display:flex;flex-direction:column;gap:0.75rem">
            {[
              ['✅', 'Kids menu: yes/no/likely — not just "child-friendly"'],
              ['🛻', 'Buggy accessibility — because this matters enormously'],
              ['🪑', 'Highchair availability — confirmed, not assumed'],
              ['🔊', 'Noise level — quiet, moderate, or lively'],
              ['👶', 'Best for age range — babies through to teens'],
              ['🚿', 'Baby changing — because you need to know'],
            ].map(([emoji, text]) => (
              <li style="display:flex;gap:0.75rem;align-items:flex-start">
                <span style="font-size:1.1rem;flex-shrink:0">{emoji}</span>
                <span style="font-size:0.925rem">{text}</span>
              </li>
            ))}
          </ul>
        </div>
        <div style="background:var(--color-bg-soft);border-radius:var(--radius-lg);padding:2rem">
          <p style="font-style:italic;font-size:1.05rem;margin-bottom:1rem;color:var(--color-text-muted)">
            "Finally a restaurant guide that tells me if I can park my double buggy. This is the only one I use now."
          </p>
          <p style="font-size:0.875rem;font-weight:600">— Emma, mum of two, Clapham</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Email capture -->
  <section class="email-signup">
    <div class="container">
      <h2>Get our free guide: London's 20 best restaurants for under-5s</h2>
      <p>Join 2,000+ London parents who get our monthly roundup of the best family dining — new openings, seasonal picks, and places kids actually love.</p>
      <form
        class="email-form"
        action="https://app.mailchimp.com/subscribe/post"
        method="POST"
        target="_blank"
        id="email-signup-form"
      >
        <!-- Replace with your Mailchimp embed URL -->
        <input type="hidden" name="u" value="MAILCHIMP_USER_ID" />
        <input type="hidden" name="id" value="MAILCHIMP_LIST_ID" />
        <input
          type="email"
          name="EMAIL"
          placeholder="Your email address"
          required
          aria-label="Email address"
        />
        <button type="submit">Get the free guide →</button>
      </form>
      <p class="email-signup__small">No spam. Unsubscribe any time. Your email is never shared.</p>
    </div>
  </section>

  <script>
    // Hero search — redirect to neighbourhood or filter
    const searchInput = document.getElementById('hero-search') as HTMLInputElement;
    const searchBtn = document.getElementById('hero-search-btn');

    const neighbourhoodSlugs: Record<string, string> = {
      clapham: '/clapham',
      'notting hill': '/notting-hill',
      islington: '/islington',
      richmond: '/richmond',
      shoreditch: '/shoreditch',
    };

    function handleSearch() {
      const q = searchInput.value.toLowerCase().trim();
      for (const [term, url] of Object.entries(neighbourhoodSlugs)) {
        if (q.includes(term)) {
          window.location.href = url;
          return;
        }
      }
      // Default: go to first neighbourhood page
      if (q) window.location.href = `/clapham?q=${encodeURIComponent(q)}`;
    }

    searchBtn?.addEventListener('click', handleSearch);
    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') handleSearch();
    });
  </script>
</Base>
