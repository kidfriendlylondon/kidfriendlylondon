---
import Base from '../layouts/Base.astro';
import ListingCard from '../components/ListingCard.astro';
import FilterBar from '../components/FilterBar.astro';
import RestaurantMap from '../components/RestaurantMap.astro';
import { restaurants, getFeaturedRestaurants, neighbourhoodMeta } from '../data/restaurants';

const featured = getFeaturedRestaurants();
const totalListings = restaurants.length;

// Build the lean data object for the map (no need to pass the full Restaurant shape)
const mapData = restaurants
  .filter((r) => r.lat && r.lng)
  .map((r) => ({
    slug: r.slug,
    name: r.name,
    neighbourhoodName: neighbourhoodMeta[r.neighbourhood].name,
    cuisineType: r.cuisineType,
    priceRange: r.priceRange,
    lat: r.lat!,
    lng: r.lng!,
    kidsMenu: r.kidsMenu,
    highchairs: r.highchairs,
    buggyAccessible: r.buggyAccessible,
    softPlay: r.softPlay,
    outdoorPark: r.outdoorPark,
    outdoorSpace: r.outdoorSpace,
    veganOptions: r.veganOptions,
    glutenFreeOptions: r.glutenFreeOptions,
    halalOptions: r.halalOptions,
  }));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Kid Friendly London',
  url: 'https://kidfriendlylondon.co.uk',
  description:
    'The most comprehensive guide to kid-friendly and family restaurants in London. Filter by neighbourhood, features, price, and more.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://kidfriendlylondon.co.uk/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<Base
  title="Kid Friendly Restaurants London — Family Dining Guide | Kid Friendly London"
  description="The most comprehensive guide to kid-friendly restaurants in London. Filter by neighbourhood, highchairs, kids menu, outdoor space, buggy access and more. 130+ enriched listings across Clapham, Notting Hill, Islington, Richmond and Shoreditch."
  schema={schema}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero__eyebrow">London's most detailed family dining guide</p>
      <h1 class="hero__title">
        London's most trusted guide to family dining
      </h1>
      <p class="hero__subtitle">
        Every restaurant is checked for the things parents actually need — highchairs, buggy access, kids menus, outdoor space, noise level, and more.
      </p>

      <div class="hero__trust">
        <div class="trust-item"><strong>{totalListings}+</strong> restaurants reviewed</div>
        <div class="trust-item"><strong>5</strong> London neighbourhoods</div>
        <div class="trust-item">Updated <strong>weekly</strong></div>
        <div class="trust-item">Built by <strong>parents</strong>, for parents</div>
      </div>
    </div>
  </section>

  <!-- Map + filters (replaces neighbourhood cards) -->
  <section class="map-section section">
    <div class="container">
      <h2 style="margin-bottom:0.5rem">Explore restaurants on the map</h2>
      <p class="text-muted" style="margin-bottom:1.25rem;font-size:0.95rem">
        Filter by what matters to your family, then click any pin for details.
      </p>
      <RestaurantMap
        restaurants={mapData}
        showFilters={true}
        height="520px"
        mapId="home-map"
      />
    </div>
  </section>

  <!-- Featured listings with filter -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom:0.5rem">Featured restaurants</h2>
      <p class="text-muted" style="margin-bottom:1.5rem;font-size:0.95rem">Handpicked favourites — the best of the best for London families.</p>

      <FilterBar />

      <div class="listings-grid" id="listings-grid">
        {featured.map((r) => <ListingCard restaurant={r} />)}
      </div>
      <div id="no-results" class="no-results" style="display:none">
        <p>No restaurants match your current filters. <button class="filter-reset" onclick="document.getElementById('filter-reset').click()">Clear filters</button></p>
      </div>
    </div>
  </section>

  <!-- Borough links -->
  <section class="section section--soft">
    <div class="container">
      <h2 style="margin-bottom:1.5rem">Browse by borough</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem">
        {[
          { href: '/south-london', name: 'South London', emoji: '🌳', desc: 'Clapham, Richmond' },
          { href: '/north-london', name: 'North London', emoji: '🎭', desc: 'Islington, Highbury' },
          { href: '/west-london', name: 'West London', emoji: '🎡', desc: 'Notting Hill, Kensington' },
          { href: '/east-london', name: 'East London', emoji: '🎨', desc: 'Shoreditch, Spitalfields' },
        ].map((b) => (
          <a href={b.href} class="neighbourhood-card">
            <div class="neighbourhood-card__emoji">{b.emoji}</div>
            <div class="neighbourhood-card__name">{b.name}</div>
            <div class="neighbourhood-card__count">{b.desc}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AdSense unit -->
  <div class="container">
    <div class="ad-unit">Advertisement — Google AdSense (insert ad code here)</div>
  </div>

  <!-- Why different -->
  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center">
        <div>
          <h2 style="margin-bottom:1rem">Why Kid Friendly London is different</h2>
          <p style="margin-bottom:1.5rem;color:var(--color-text-muted)">
            Every other list tells you a restaurant is "family-friendly." We tell you <em>why</em> — and exactly what to expect.
          </p>
          <ul style="display:flex;flex-direction:column;gap:0.75rem">
            {[
              ['✅', 'Kids menu: yes/no/likely — not just "child-friendly"'],
              ['🛻', 'Buggy accessibility — because this matters enormously'],
              ['🪑', 'Highchair availability — confirmed, not assumed'],
              ['🔊', 'Noise level — quiet, moderate, or lively'],
              ['👶', 'Best for age range — babies through to teens'],
              ['🚿', 'Baby changing — because you need to know'],
            ].map(([emoji, text]) => (
              <li style="display:flex;gap:0.75rem;align-items:flex-start">
                <span style="font-size:1.1rem;flex-shrink:0">{emoji}</span>
                <span style="font-size:0.925rem">{text}</span>
              </li>
            ))}
          </ul>
        </div>
        <div style="background:var(--color-bg-soft);border-radius:var(--radius-lg);padding:2rem;border:1px solid var(--color-border)">
          <p style="font-family:Georgia,serif;font-style:italic;font-size:1.1rem;margin-bottom:1rem;color:var(--color-text);line-height:1.6">
            "Finally a restaurant guide that tells me if I can park my double buggy. This is the only one I use now."
          </p>
          <p style="font-size:0.875rem;font-weight:600;color:var(--color-text-muted)">— Emma, mum of two, Clapham</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Email capture -->
  <section class="email-signup">
    <div class="container">
      <h2>Get our free guide: London's 20 best restaurants for under-5s</h2>
      <p>Join 2,000+ London parents who get our monthly roundup of the best family dining — new openings, seasonal picks, and places kids actually love.</p>
      <form
        class="email-form"
        action="https://vanbuildlab.us12.list-manage.com/subscribe/post?u=8a8b8e9f2c83958dbc1527ee5&id=db04ea47c8&f_id=00b8d6e8f0"
        method="POST"
        target="_blank"
        id="email-signup-form"
      >
        <input
          type="email"
          name="EMAIL"
          placeholder="Your email address"
          required
          aria-label="Email address"
        />
        <button type="submit">Get the free guide →</button>
      </form>
      <p class="email-signup__small">No spam. Unsubscribe any time. Your email is never shared.</p>
    </div>
  </section>
</Base>
