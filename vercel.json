{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "rewrites": [
    { "source": "/south-london", "destination": "/borough/south-london" },
    { "source": "/north-london", "destination": "/borough/north-london" },
    { "source": "/west-london", "destination": "/borough/west-london" },
    { "source": "/east-london", "destination": "/borough/east-london" },
    { "source": "/central-london", "destination": "/borough/central-london" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|woff2|png|jpg|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
